class Solution {
    public boolean checkOnesSegment(String s) {
        boolean seenZeroAfterOne = false;
        for (char c : s.toCharArray()) {
            if (seenZeroAfterOne && c == '1') {
                return false;
            }
            if (c == '0') {
                seenZeroAfterOne = true;
            }
        }
        return true;
    }
}
